<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowIsTranslucent">false</item>
        <!-- SplashScreen compat attributes (no android: prefix) for API < 31 -->
        <item name="windowSplashScreenBackground">#05030A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
        <item name="windowSplashScreenIconBackgroundColor">#05030A</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowBackground">#05030A</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>
