<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Flutter LaunchTheme: shown while Flutter engine loads -->
    <style name="LaunchTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowIsTranslucent">false</item>
        <!-- SplashScreen compat attributes (no android: prefix) for API < 31 -->
        <item name="windowSplashScreenBackground">#05030A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
        <item name="windowSplashScreenIconBackgroundColor">#05030A</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.NoTitleBar">
        <item name="android:windowBackground">#05030A</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
    <!--
        UCropActivity theme: keeps the navigation bar opaque and dark so the
        crop controls are never hidden behind the system nav bar.
        The Flutter app uses SystemUiMode.edgeToEdge which makes the nav bar
        transparent, but UCropActivity is a separate Android Activity that
        needs to handle its own insets.
    -->
    <style name="UCropTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">#FF0D0B14</item>
        <item name="android:navigationBarColor">#FF0D0B14</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
