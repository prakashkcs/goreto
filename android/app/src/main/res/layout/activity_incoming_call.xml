<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Blurred/dimmed background (caller's cover photo) -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.45"
        android:src="@drawable/ic_default_avatar" />

    <!-- Dark gradient overlay (bottom half) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/call_gradient_overlay" />

    <!-- Top section: caller info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="top"
        android:paddingTop="80dp"
        android:paddingBottom="24dp">

        <!-- Caller avatar (circular) -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/ivCallerAvatar"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_avatar"
                android:background="@drawable/circle_avatar_bg"
                android:clipToOutline="true"
                android:elevation="2dp" />

            <!-- Pulsing ring (outer) -->
            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/circle_ring_pulse"
                android:alpha="0.4" />
        </FrameLayout>

        <!-- Caller name -->
        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Caller Name"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- Call type label -->
        <TextView
            android:id="@+id/tvCallType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Incoming Video Call"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:letterSpacing="0.05" />

        <!-- Animated dots "ringing..." -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="● ● ●"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.3" />

    </LinearLayout>

    <!-- Bottom section: Accept / Decline buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:paddingBottom="72dp"
        android:paddingHorizontal="40dp">

        <!-- Decline button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/btn_decline_bg"
                android:src="@drawable/ic_call_end"
                android:scaleType="center"
                android:contentDescription="Decline call"
                android:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Decline"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Accept button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAccept"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/btn_accept_bg"
                android:src="@drawable/ic_call_accept"
                android:scaleType="center"
                android:contentDescription="Accept call"
                android:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Accept"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
