<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- Blurred background avatar -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.45"
        android:src="@drawable/ic_default_avatar" />

    <!-- Dark gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/call_gradient_overlay" />

    <!-- Top section: sender info (mirrors incoming-call layout) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="top"
        android:paddingTop="80dp"
        android:paddingBottom="24dp">

        <!-- Sender avatar (circular) with pulsing ring -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp">

            <ImageView
                android:id="@+id/ivSenderAvatar"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_avatar"
                android:background="@drawable/circle_avatar_bg"
                android:clipToOutline="true"
                android:elevation="2dp" />

            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/circle_ring_pulse"
                android:alpha="0.4" />
        </FrameLayout>

        <!-- Sender name -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Someone"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- Subtitle: "is nearby" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="is nearby right now"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:letterSpacing="0.05" />

        <!-- Animated dots -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="● ● ●"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.3" />

    </LinearLayout>

    <!-- Top-right close (small) — keeps original behaviour -->
    <FrameLayout
        android:id="@+id/btnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/circle_avatar_bg">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="✕"
            android:textColor="#AAFFFFFF"
            android:textSize="16sp" />
    </FrameLayout>

    <!-- Bottom: Ignore / Connect circular buttons (mirrors call decline/accept) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:paddingBottom="72dp"
        android:paddingHorizontal="40dp">

        <!-- Ignore (left, red) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnIgnore"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/btn_decline_bg"
                android:src="@drawable/ic_call_end"
                android:scaleType="center"
                android:contentDescription="Ignore"
                android:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Ignore"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Connect (right, green/accept) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnConnect"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/btn_accept_bg"
                android:src="@drawable/ic_call_accept"
                android:scaleType="center"
                android:contentDescription="View profile"
                android:elevation="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Say Hi"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
