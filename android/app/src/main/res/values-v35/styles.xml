<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 15 (API 35) enforces edge-to-edge for all activities.
        Opt UCropActivity out so its crop controls are not hidden behind
        the system navigation bar.
    -->
    <style name="UCropTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">#FF0D0B14</item>
        <item name="android:navigationBarColor">#FF0D0B14</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
